import type { Metadata, ResolvingMetadata } from "next";

    

    
export async function generateMetadata(
  { params, searchParams }: SeoServerSkeletonProps,
  parent: ResolvingMetadata
): Promise<Metadata> {
  const ctx = await makeAppRouterPageCtx({ params, searchParams });
  const metadata = generateDynamicMetadata({}, ctx);

  return { ...(await parent), ...metadata } as unknown as Metadata;
}


    

    async function Seo({ params, searchParams }: SeoServerSkeletonProps) {
      // Use PlasmicSeo to render this component as it was
