{
  "name": "loader-tests",
  "version": "1.0.0",
  "main": "index.js",
  "author": "Chung Wu",
  "license": "MIT",
  "private": true,
  "scripts": {
    "prepare": "playwright install chromium",
    "playwright-ui": "playwright test --ui",
    "test": "yarn test-playwright",
    "test-docker": "yarn docker-build && yarn docker-run",
    "update-snapshots": "PLAYWRIGHT_REPORTER_OPEN=never npx playwright test --update-snapshots",
    "docker-build": "docker build --no-cache -t loader-tests .",
    "docker-run": "docker run --add-host host.docker.internal:host-gateway --rm loader-tests",
    "test-playwright": "npx playwright test",
    "local:playwright-ui": "NPM_CONFIG_REGISTRY=http://localhost:4873 yarn run playwright-ui"
  },
  "devDependencies": {
    "@types/fs-extra": "^9.0.12",
    "@types/node-fetch": "^2.5.12",
    "@types/tmp": "^0.2.1",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@playwright/test": "^1.60.0",
    "execa": "^5.1.1",
    "fs-extra": "^10.0.0",
    "get-port": "^5.1.1",
    "node-fetch": "^2",
    "playwright-ctrf-json-reporter": "^0.0.29",
    "tmp": "^0.2.1"
  }
}
