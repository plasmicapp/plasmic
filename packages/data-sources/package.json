{
  "version": "1.0.14",
  "name": "@plasmicapp/data-sources",
  "license": "MIT",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.esm.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=10"
  },
  "scripts": {
    "build": "pnpm build:types && pnpm build:index",
    "build:types": "tsc",
    "build:index": "node ../../build.mjs ./src/index.tsx",
    "test": "vitest run --silent=passed-only",
    "lint": "eslint",
    "prepublishOnly": "npm run build",
    "postpublish": "bash ../../scripts/publish-api-doc-model.sh",
    "size": "size-limit",
    "analyze": "size-limit --why"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "10 KB"
    }
  ],
  "devDependencies": {
    "@types/react": "^18",
    "react": "^18.3.1",
    "vitest": "3.2.4"
  },
  "dependencies": {
    "@plasmicapp/data-sources-context": "0.1.23",
    "@plasmicapp/host": "2.0.6",
    "@plasmicapp/isomorphic-unfetch": "1.0.3",
    "@plasmicapp/query": "0.1.84",
    "fast-stringify": "^2.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
