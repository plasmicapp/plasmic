{
  "version": "1.0.85",
  "license": "MIT",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.esm.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=10"
  },
  "scripts": {
    "build": "pnpm build:types && pnpm build:index",
    "build:types": "tsc",
    "build:index": "node ../../build.mjs ./src/index.ts",
    "test": "TEST_CWD=`pwd` pnpm -w test",
    "lint": "eslint",
    "prepublishOnly": "npm run build",
    "postpublish": "bash ../../scripts/publish-api-doc-model.sh",
    "size": "size-limit",
    "analyze": "size-limit --why"
  },
  "name": "@plasmicapp/watcher",
  "author": "Chung Wu",
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "10 KB"
    }
  ],
  "devDependencies": {
    "@types/socket.io-client": "^3.0.0"
  },
  "dependencies": {
    "socket.io-client": "^4.1.2"
  },
  "gitHead": "fa53f7d79f0e26d8b061102fda0c06788da6f8a7"
}
